.page { min-height:100vh; background:#0A0A1A; padding:40rpx; color:#fef3c7; }
.emoji { font-size:96rpx; display:block; text-align:center; }
.title { font-size:42rpx; font-weight:900; display:block; text-align:center; margin-top:16rpx; }
.desc { font-size:24rpx; color:#888; display:block; text-align:center; margin-top:12rpx; white-space:pre-line; }

.input-item { margin:40rpx 0 24rpx; }
.input-label { font-size:24rpx; color:#888; display:block; margin-bottom:8rpx; }
.input {
  width:100%; height:88rpx; background:rgba(26,26,46,0.9);
  border:1rpx solid rgba(251,191,36,0.15); border-radius:16rpx;
  padding:0 24rpx; font-size:30rpx; color:#fbbf24; box-sizing:border-box;
}

.picker-row { display:flex; gap:16rpx; margin-bottom:40rpx; }
.picker-item {
  flex:1; background:rgba(26,26,46,0.9);
  border:1rpx solid rgba(251,191,36,0.15); border-radius:16rpx; padding:20rpx;
}
.picker-label { font-size:20rpx; color:#888; display:block; margin-bottom:4rpx; }
.picker-value { font-size:28rpx; color:#fbbf24; display:block; }

.btn-glow { display:block; width:360rpx; margin:0 auto; }

.result-title { font-size:48rpx; font-weight:900; display:block; text-align:center;
  background:linear-gradient(135deg,#fbbf24,#c084fc); -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}

.num-grid { display:grid; grid-template-columns:1fr 1fr; gap:16rpx; margin:40rpx 0; }
.num-card {
  background:linear-gradient(135deg,rgba(26,26,46,0.9),rgba(15,15,27,0.9));
  border:1rpx solid rgba(251,191,36,0.15); border-radius:20rpx; padding:24rpx; text-align:center;
}
.num-label { font-size:20rpx; color:#666; display:block; }
.num-value { font-size:56rpx; font-weight:900; color:#fbbf24; display:block; margin:8rpx 0; }
.num-value.master { color:#c084fc; }
.num-master { font-size:18rpx; color:#c084fc; display:block; }
.num-desc { font-size:20rpx; color:#666; display:block; margin-top:8rpx; }

.card {
  background:linear-gradient(135deg,rgba(26,26,46,0.9),rgba(15,15,27,0.9));
  border:1rpx solid rgba(251,191,36,0.15); border-radius:20rpx; padding:28rpx; margin-top:20rpx;
}
.card-title { font-size:30rpx; font-weight:bold; color:#fbbf24; margin-bottom:12rpx; }
.card-text { font-size:26rpx; color:#aaa; line-height:1.8; }

.btn-purple { display:block; width:360rpx; margin:40rpx auto 0; }