.container {
  width: 100vw;
  height: 100vh;
  background: #0A0A1A;
  position: relative;
  overflow: hidden;
}

.canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.overlay {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  height: 100vh;
  box-sizing: border-box;
  pointer-events: none;
}

.title-group {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  font-size: 72rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #fbbf24, #f59e0b, #a855f7);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: block;
  letter-spacing: 16rpx;
  text-shadow: 0 0 60rpx rgba(251,191,36,0.3);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(251, 191, 36, 0.6);
  margin-top: 16rpx;
  display: block;
}

.altar-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
  padding: 0 40rpx;
  max-width: 700rpx;
  pointer-events: auto;
}

.altar-card {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, rgba(26,26,46,0.9), rgba(15,15,27,0.9));
  border: 2rpx solid var(--color);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 0 30rpx var(--color);
  transition: all 0.3s;
}

.altar-card:active {
  transform: scale(1.08);
  box-shadow: 0 0 50rpx var(--color);
}

.altar-icon {
  font-size: 48rpx;
}

.altar-label {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color);
}

.altar-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
}

.hint {
  position: fixed;
  bottom: 40rpx;
  width: 100%;
  text-align: center;
  z-index: 10;
  pointer-events: none;
}

.hint text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
}