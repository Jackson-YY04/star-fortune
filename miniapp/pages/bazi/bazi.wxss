.page { min-height:100vh; background:#0A0A1A; padding:40rpx; color:#fef3c7; }
.emoji { font-size:96rpx; display:block; text-align:center; }
.title { font-size:42rpx; font-weight:900; display:block; text-align:center; margin-top:16rpx; }
.desc { font-size:24rpx; color:#888; display:block; text-align:center; margin-top:8rpx; }

.picker-grid { display:grid; grid-template-columns:1fr 1fr; gap:24rpx; margin:48rpx 0; }
.picker-item {
  background:rgba(26,26,46,0.9); border:1rpx solid rgba(251,191,36,0.15);
  border-radius:16rpx; padding:24rpx;
}
.picker-label { font-size:22rpx; color:#888; display:block; margin-bottom:8rpx; }
.picker-value { font-size:32rpx; color:#fbbf24; display:block; }

.btn-glow { display:block; width:360rpx; margin:0 auto; }

.result-title { font-size:48rpx; font-weight:900; display:block; text-align:center;
  background:linear-gradient(135deg,#fbbf24,#4ade80); -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}

.pillars { display:flex; gap:16rpx; margin:40rpx 0; }
.pillar {
  flex:1; background:linear-gradient(135deg,rgba(26,26,46,0.9),rgba(15,15,27,0.9));
  border:1rpx solid rgba(251,191,36,0.15); border-radius:16rpx; padding:24rpx; text-align:center;
}
.pillar-label { font-size:20rpx; color:#666; display:block; }
.pillar-stem { font-size:40rpx; font-weight:900; color:#fbbf24; display:block; margin:8rpx 0; }
.pillar-branch { font-size:24rpx; color:#888; display:block; }

.card {
  background:linear-gradient(135deg,rgba(26,26,46,0.9),rgba(15,15,27,0.9));
  border:1rpx solid rgba(251,191,36,0.15); border-radius:20rpx; padding:28rpx; margin-top:24rpx;
}
.card-title { font-size:32rpx; font-weight:bold; color:#fbbf24; margin-bottom:16rpx; }
.card-text { font-size:26rpx; color:#aaa; line-height:1.8; }

.elem-bar { display:flex; align-items:center; gap:16rpx; margin:12rpx 0; }
.elem-label { width:40rpx; font-size:24rpx; font-weight:bold; }
.elem-track { flex:1; height:24rpx; background:rgba(255,255,255,0.05); border-radius:12rpx; overflow:hidden; }
.elem-fill { height:100%; border-radius:12rpx; transition: width 0.6s; }
.elem-count { width:40rpx; font-size:24rpx; color:#888; text-align:right; }

.btn-purple { display:block; width:360rpx; margin:40rpx auto 0; }