.page { min-height:100vh; background:#0A0A1A; padding:40rpx; color:#fef3c7; }
.emoji { font-size:96rpx; display:block; text-align:center; }
.title { font-size:42rpx; font-weight:900; display:block; text-align:center; margin-top:16rpx; }
.desc { font-size:24rpx; color:#888; display:block; text-align:center; margin-top:12rpx; white-space:pre-line; }

.upload-box {
  margin:48rpx auto; width:560rpx; height:400rpx;
  border:2rpx dashed rgba(251,191,36,0.25);
  border-radius:24rpx;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  position:relative;
}
.upload-icon { font-size:64rpx; margin-bottom:16rpx; }
.upload-text { font-size:28rpx; color:rgba(251,191,36,0.6); }

.corner { position:absolute; width:40rpx; height:40rpx; border-color:rgba(251,191,36,0.5); }
.tl { top:0; left:0; border-top:2rpx solid rgba(251,191,36,0.5); border-left:2rpx solid rgba(251,191,36,0.5); }
.tr { top:0; right:0; border-top:2rpx solid rgba(251,191,36,0.5); border-right:2rpx solid rgba(251,191,36,0.5); }
.bl { bottom:0; left:0; border-bottom:2rpx solid rgba(251,191,36,0.5); border-left:2rpx solid rgba(251,191,36,0.5); }
.br { bottom:0; right:0; border-bottom:2rpx solid rgba(251,191,36,0.5); border-right:2rpx solid rgba(251,191,36,0.5); }

.preview-wrap { margin:48rpx auto; }
.preview-box {
  width:560rpx; height:400rpx; border-radius:24rpx; overflow:hidden;
  border:2rpx solid rgba(251,191,36,0.3); position:relative;
}
.preview-img { width:100%; height:100%; }
.scan-line {
  position:absolute; top:0; left:0; width:100%; height:2rpx;
  background:linear-gradient(to right, transparent, #fbbf24, transparent);
  z-index:2;
  animation: scan 2s infinite;
}
@keyframes scan { from { top:5%; } to { top:95%; } }
.preview-actions { text-align:center; margin-top:20rpx; }
.action-link { font-size:26rpx; color:#fbbf24; }

.btn-glow { display:block; width:360rpx; margin:0 auto; }

.result-title { font-size:48rpx; font-weight:900; display:block; text-align:center;
  background:linear-gradient(135deg,#fbbf24,#fdba74); -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}

.line-card {
  background:linear-gradient(135deg,rgba(26,26,46,0.9),rgba(15,15,27,0.9));
  border:1rpx solid rgba(251,191,36,0.15); border-radius:20rpx; padding:28rpx; margin-top:20rpx;
}
.line-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:12rpx; }
.line-name { font-size:32rpx; font-weight:bold; color:#fbbf24; }
.line-badge { font-size:20rpx; padding:4rpx 16rpx; border-radius:16rpx; }
.line-badge.long { background:rgba(74,222,128,0.1); color:#4ade80; }
.line-badge.medium { background:rgba(251,191,36,0.1); color:#fbbf24; }
.line-badge.short { background:rgba(248,113,113,0.1); color:#f87171; }
.line-badge.yes { background:rgba(74,222,128,0.1); color:#4ade80; }
.line-badge.no { background:rgba(255,255,255,0.05); color:#666; }
.line-mean { font-size:26rpx; color:#aaa; line-height:1.8; }

.btn-purple { display:block; width:360rpx; margin:40rpx auto 0; }